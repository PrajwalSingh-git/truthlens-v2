# Supabase project settings — Settings > API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-username.github.io

# Optional — enable LLM-backed analysis instead of the offline heuristic
# engine. Anthropic is preferred if both are set. Leave both blank to use
# the built-in heuristic engine (works out of the box, no key needed).
#   Anthropic: https://console.anthropic.com (paid, small free credit on signup)
#   Groq:      https://console.groq.com      (free tier, OpenAI-compatible)
ANTHROPIC_API_KEY=
GROQ_API_KEY=
